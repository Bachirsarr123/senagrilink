APP_NAME="SenAgriLink"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://senagrilink-backend.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Base de données (PostgreSQL) ──────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=agri_platform
DB_USERNAME=agri_user
DB_PASSWORD=secret
DB_SSLMODE=require

# ── Sessions / Cache / Files / Queue ──────────────────────────────────────────
BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true

# ── CORS / Sanctum ─────────────────────────────────────────────────────────────
# URL complète du frontend Angular déployé (sans slash final), utilisée par
# config/cors.php pour whitelister les origines autorisées en production.
FRONTEND_URL=https://senagrilink-frontend.onrender.com
SANCTUM_STATEFUL_DOMAINS=localhost:4200

# ── Mail ───────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@senagrilink.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Stockage cloud (optionnel, si FILESYSTEM_DISK=s3) ─────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
